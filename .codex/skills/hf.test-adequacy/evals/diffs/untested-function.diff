+
+
+def format_json_report(data: dict[str, Any], *, indent: int = 2) -> str:
+    """Format data as a pretty-printed JSON report with metadata header."""
+    header = f"# Report: {data.get('title', 'Untitled')}\n"
+    body = json.dumps(data, indent=indent, default=str)
+    return header + body
+
+
+def format_csv(rows: list[dict], headers: list[str]) -> str:
+    """Format rows as CSV string."""
+    lines = [",".join(headers)]
+    for row in rows:
+        values = []
+        for h in headers:
+            val = str(row.get(h, ""))
+            if "," in val or '"' in val:
+                val = f'"{val}"'
+            values.append(val)
+        lines.append(",".join(values))
+    return "\n".join(lines)
