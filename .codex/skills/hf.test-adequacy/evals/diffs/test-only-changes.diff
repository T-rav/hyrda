+def test_ensure_dir_returns_existing(tmp_path):
+    """Calling ensure_dir on an existing directory is a no-op."""
+    existing = tmp_path / "already_here"
+    existing.mkdir()
+    result = ensure_dir(existing)
+    assert result == existing
